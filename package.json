{
  "name": "deft-engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript engine monorepo for the deft directive framework (Wave-1 scaffold, #1717).",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^3",
    "typescript": "^5",
    "vitest": "^3"
  }
}
