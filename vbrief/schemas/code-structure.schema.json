{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deft.dev/schemas/code-structure-0.1.schema.json",
  "title": "Directive codeStructure Profile v0.1",
  "description": "Authored codebase-structure metadata for #1595. Generated MAPs, indexes, and headers are projections of this record.",
  "type": "object",
  "required": [
    "version",
    "modules",
    "pathOwnership",
    "allowedPatterns",
    "projectionManifest"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1"
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/module"
      }
    },
    "pathOwnership": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pathOwnership"
      }
    },
    "allowedPatterns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/allowedPattern"
      }
    },
    "projectionManifest": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projection"
      }
    },
    "filePurposeOverrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/filePurposeOverride"
      }
    },
    "glossaryRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/glossaryRef"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1
    },
    "module": {
      "type": "object",
      "required": [
        "id",
        "name",
        "purpose",
        "pathGlobs"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "pathGlobs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/relativePath"
          }
        },
        "owner": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "pathOwnership": {
      "type": "object",
      "required": [
        "pathGlob",
        "module"
      ],
      "properties": {
        "pathGlob": {
          "$ref": "#/$defs/relativePath"
        },
        "module": {
          "$ref": "#/$defs/stableId"
        },
        "owner": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "allowedPattern": {
      "type": "object",
      "required": [
        "id",
        "module",
        "name",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stableId"
        },
        "module": {
          "$ref": "#/$defs/stableId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "appliesTo": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relativePath"
          }
        },
        "forbidden": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "projection": {
      "type": "object",
      "required": [
        "path",
        "kind",
        "source",
        "generated"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "kind": {
          "$ref": "#/$defs/stableId"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "generated": {
          "type": "boolean"
        },
        "task": {
          "type": "string"
        },
        "freshnessTask": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "filePurposeOverride": {
      "type": "object",
      "required": [
        "path",
        "purpose"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "module": {
          "$ref": "#/$defs/stableId"
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "glossaryRef": {
      "type": "object",
      "required": [
        "term"
      ],
      "properties": {
        "term": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "$ref": "#/$defs/relativePath"
        }
      },
      "additionalProperties": true
    }
  }
}
